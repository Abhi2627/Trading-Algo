{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AlgoTrade",
  "version": "0.1.0",
  "identifier": "com.abhaydandge.algotrade",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AlgoTrade — Paper Trading",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 680,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' http://139.59.23.105:8000 http://localhost:8000; connect-src http://139.59.23.105:8000 http://localhost:8000 ws: wss:; img-src 'self' data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "10.13",
      "exceptionDomain": "139.59.23.105"
    }
  }
}
